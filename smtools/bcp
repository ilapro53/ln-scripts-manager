#!/bin/bash

WORKDIR="."

usage() {
    echo "Использование: bcp [опции] <команда> [имя]"
    echo "Опции:"
    echo "  -d, --dir <папка>     Папка для бэкапов"
    echo "Команды:"
    echo "  create <имя>     Создать пустую папку бэкапа"
    echo "  edit <имя>       Редактировать .bcpdirs.txt"
    echo "  backup <имя>      Создать бэкап"
    echo "  restore <имя>    Восстановить из бэкапа"
    echo "  delete <имя>     Удалить бэкап"
    echo "  list             Список бэкапов"
    exit 1
}

ARGS=()
while [ $# -gt 0 ]; do
    case "$1" in
        -d|--dir)
            WORKDIR="$2"
            shift 2
            ;;
        -*)
            usage
            ;;
        *)
            ARGS+=("$1")
            shift
            ;;
    esac
done

BACKUPS_DIR="$WORKDIR/backups"

get_backup_dir() { echo "$BACKUPS_DIR/$1"; }
get_dirs_file() { echo "$BACKUPS_DIR/$1.bcpdirs.txt"; }
get_meta_file() { echo "$BACKUPS_DIR/$1.bcp.json"; }

bcp_list() {
    [ ! -d "$BACKUPS_DIR" ] && echo "Нет бэкапов" && return
    find "$BACKUPS_DIR" -maxdepth 1 -type d | tail -n +2 | sed "s|$BACKUPS_DIR/||" | sort
}

bcp_create() {
    local NAME="$1"
    local DIR="$(get_backup_dir "$NAME")"
    local DIRS_FILE="$(get_dirs_file "$NAME")"
    
    [ -z "$NAME" ] && echo "Укажите имя" && exit 1
    [ -d "$DIR" ] || [ -f "$DIRS_FILE" ] && echo "Уже существует: $NAME" && exit 1
    
    mkdir -p "$DIR" && touch "$DIRS_FILE"
    echo "Создано: $NAME"
}

bcp_edit() {
    local NAME="$1"
    local DIRS_FILE="$(get_dirs_file "$NAME")"
    
    [ -z "$NAME" ] && echo "Укажите имя" && exit 1
    [ ! -f "$DIRS_FILE" ] && echo "Не существует: $NAME" && exit 1
    
    if [ -t 0 ] && command -v nano >/dev/null 2>&1; then
        nano "$DIRS_FILE"
    else
        echo "Введите директории:"
        CONTENT=$(cat | sed 's|^\./||')
        echo "$CONTENT" > "$DIRS_FILE"
    fi
    echo "Сохранено: $NAME"
}

bcp_backup() {
    local NAME="$1"
    local DIR="$(get_backup_dir "$NAME")"
    local DIRS_FILE="$(get_dirs_file "$NAME")"
    local META_FILE="$(get_meta_file "$NAME")"
    local TMP_JSON=$(mktemp)
    
    [ -z "$NAME" ] && echo "Укажите имя" && exit 1
    [ ! -f "$DIRS_FILE" ] && echo "Не существует: $NAME" && exit 1
    
    rm -rf "$DIR" "$META_FILE"
    mkdir -p "$DIR"
    
    > "$TMP_JSON"
    
    while IFS= read -r line || [ -n "$line" ]; do
        line="${line#./}"
        [ -z "$line" ] && continue
        
        # Обрабатываем и файлы, и папки
        if [ -d "$line" ]; then
            for file in "$line"/*; do
                [ -f "$file" ] || continue
                HASH=$(sha256sum "$file" | cut -d' ' -f1)
                BASENAME=$(basename "$file")
                cp "$file" "$DIR/$HASH.bcpf"
                echo "    \"$line/$BASENAME\": \"$HASH.bcpf\"," >> "$TMP_JSON"
            done
        elif [ -f "$line" ]; then
            HASH=$(sha256sum "$line" | cut -d' ' -f1)
            BASENAME=$(basename "$line")
            cp "$line" "$DIR/$HASH.bcpf"
            echo "    \"$BASENAME\": \"$HASH.bcpf\"," >> "$TMP_JSON"
        fi
    done < "$DIRS_FILE"
    
    NOW=$(date -Iseconds)
    {
        echo "{"
        echo "  \"name\": \"$NAME\","
        echo "  \"time\": \"$NOW\","
        echo "  \"files\": {"
        [ -s "$TMP_JSON" ] && sed '$ s/,$//' "$TMP_JSON"
        echo "  }"
        echo "}"
    } > "$META_FILE"
    rm -f "$TMP_JSON"
    
    echo "Готово: $NAME"
}

bcp_restore() {
    local NAME="$1"
    local DIR="$(get_backup_dir "$NAME")"
    local META_FILE="$(get_meta_file "$NAME")"
    
    [ -z "$NAME" ] && echo "Укажите имя" && exit 1
    [ ! -f "$META_FILE" ] && echo "Не найден: $NAME" && exit 1
    
    while IFS= read -r line; do
        echo "$line" | grep -q '":.*\.bcpf"' || continue
        
        ORIG_PATH=$(echo "$line" | sed 's/.*"\([^"]*\)":.*/\1/' | tr -d ' ')
        ORIG_PATH="${ORIG_PATH#./}"
        HASH=$(echo "$line" | sed 's/.*": *"\([^"]*\)".*/\1/')
        
        [ -z "$ORIG_PATH" ] && continue
        
        DST_DIR=$(dirname "$ORIG_PATH")
        [ -n "$DST_DIR" ] && [ "$DST_DIR" != "." ] && mkdir -p "$DST_DIR"
        
        [ -f "$DIR/$HASH" ] && mv "$DIR/$HASH" "$ORIG_PATH" && echo "Restored: $ORIG_PATH"
    done < "$META_FILE"
    
    echo "Готово: $NAME"
}

bcp_delete() {
    local NAME="$1"
    local DIR="$(get_backup_dir "$NAME")"
    local DIRS_FILE="$(get_dirs_file "$NAME")"
    local META_FILE="$(get_meta_file "$NAME")"
    
    [ -z "$NAME" ] && echo "Укажите имя" && exit 1
    [ ! -d "$DIR" ] && [ ! -f "$DIRS_FILE" ] && echo "Не существует: $NAME" && exit 1
    
    rm -rf "$DIR" "$DIRS_FILE" "$META_FILE"
    echo "Удалено: $NAME"
}

CMD="${ARGS[0]:-}"
NAME="${ARGS[1]:-}"

case "$CMD" in
    create) bcp_create "$NAME" ;;
    edit) bcp_edit "$NAME" ;;
    backup) bcp_backup "$NAME" ;;
    restore) bcp_restore "$NAME" ;;
    delete) bcp_delete "$NAME" ;;
    list) bcp_list ;;
    *) usage ;;
esac